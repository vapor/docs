<!DOCTYPE html>
<html lang="#(language.locale)">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="color-scheme" content="light dark">
    <title>#if(page.isHome):#(site.name)#else:#(page.title) · #(site.name)#endif</title>
    <link rel="canonical" href="#(page.canonicalURL)">
    #if(markdownURL):<link rel="alternate" type="text/markdown" href="#(markdownURL)">#endif
    #if(page.description):<meta name="description" content="#(page.description)">#endif
    #if(site.author):<meta name="author" content="#(site.author)">#endif
    <meta name="theme-color" content="#ffffff">
    <meta name="generator" content="Kiln">
    #if(noindex):<meta name="robots" content="noindex">#endif

    <!-- Open Graph -->
    <meta property="og:type" content="#if(page.isHome):website#else:article#endif">
    <meta property="og:title" content="#if(page.isHome):#(site.name)#else:#(page.title)#endif">
    #if(page.description):<meta property="og:description" content="#(page.description)">#endif
    <meta property="og:url" content="#(page.canonicalURL)">
    <meta property="og:site_name" content="#(site.name)">
    <meta property="og:locale" content="#if(language.ogLocale):#(language.ogLocale)#else:#(language.locale)#endif">
    #if(page.imageURL):<meta property="og:image" content="#(page.imageURL)">#endif

    <!-- Twitter -->
    <meta name="twitter:card" content="#if(page.imageURL):summary_large_image#else:summary#endif">
    #if(site.twitterSite):<meta name="twitter:site" content="#(site.twitterSite)">#endif
    <meta name="twitter:title" content="#if(page.isHome):#(site.name)#else:#(page.title)#endif">
    #if(page.description):<meta name="twitter:description" content="#(page.description)">#endif
    #if(page.imageURL):<meta name="twitter:image" content="#(page.imageURL)">#endif

    <!-- Vapor Docs favicons (new mark) -->
    <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg">
    <link rel="icon" type="image/png" sizes="96x96" href="/assets/favicon-96x96.png">
    <link rel="shortcut icon" href="/assets/favicon.ico">
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
    <meta name="apple-mobile-web-app-title" content="Vapor Docs">
    <link rel="manifest" href="/assets/site.webmanifest">

    #for(alt in languages):<link rel="alternate" hreflang="#(alt.locale)" href="#if(alt.absoluteURL):#(alt.absoluteURL)#else:#(alt.url)#endif">
    #if(alt.isDefault):<link rel="alternate" hreflang="x-default" href="#if(alt.absoluteURL):#(alt.absoluteURL)#else:#(alt.url)#endif">
    #endif#endfor

    <!-- Shared Vapor design system (header/footer chrome, brand, fonts, icons) -->
    <link rel="stylesheet" href="https://design.vapor.codes/main.css">
    <!-- Docs-specific layout layer (sidebar, content, table of contents, search) -->
    <link rel="stylesheet" href="/_kiln/css/theme.css">
    #for(href in site.extraCSS):<link rel="stylesheet" href="/#(href)">
    #endfor

    <!-- Pre-paint colour scheme. External (not inline) so the CSP needs no
         'unsafe-inline' for scripts; still synchronous, so it runs before paint. -->
    <script src="/_kiln/js/theme-init.js"></script>
    #if(page.structuredData):<script type="application/ld+json">#unsafeHTML(page.structuredData)</script>#endif
</head>
<body data-search-index="#(searchIndexURL)" data-version-base="#(versionBasePath)">
    <div class="kiln-doc-backdrop" id="kiln-doc-backdrop"></div>

    <div class="kiln-top">
    <aside class="kiln-sidebar" id="kiln-sidebar">
        <div class="kiln-sidebar-inner">
        <button class="kiln-sidebar-close" id="kiln-sidebar-close" type="button" aria-label="#(strings.toggleNavigation)">
            <span class="vapor-icon icon-x-close" aria-hidden="true"></span>
        </button>
        <a class="kiln-sidebar-brand" href="/" aria-label="#(site.name) home">
            <img class="kiln-sidebar-logo" src="/assets/vapor-logo.png" alt="" width="44" height="44">
            <span class="kiln-sidebar-brand-text">Vapor Docs</span>
        </a>
        <nav class="kiln-nav" aria-label="Documentation navigation">
            #extend("partials/nav-tree", nav)
        </nav>
        </div>
    </aside>

    <div class="kiln-shell">
        #extend("partials/header")

        <div class="kiln-layout">
        <button class="kiln-sidebar-toggle" id="kiln-sidebar-toggle" type="button" aria-label="#(strings.toggleNavigation)" aria-expanded="false" aria-controls="kiln-sidebar">
            <span class="kiln-crumb-dots" aria-hidden="true"><svg viewBox="0 0 20 20" fill="currentColor"><circle cx="3.5" cy="10" r="1.7"/><circle cx="10" cy="10" r="1.7"/><circle cx="16.5" cy="10" r="1.7"/></svg></span>
            #for(item in nav.items):#if(item.kind == "section"):#if(item.isActive):<span class="vapor-icon icon-chevron-right kiln-crumb-sep" aria-hidden="true"></span><span class="kiln-crumb-section">#(item.title)</span>#endif#endif#endfor
            <span class="vapor-icon icon-chevron-right kiln-crumb-sep" aria-hidden="true"></span>
            <span class="kiln-crumb-page">#(page.title)</span>
        </button>

        <main class="kiln-main">
            #if(site.searchEnabled):
            <div class="kiln-body-search">
                #extend("partials/search")
            </div>
            #endif

            #if(isVersioned):#if(!isLatest):
            #if(currentVersion.isPrerelease):
            <div class="admonition note kiln-version-notice">
                <p>#(strings.preReleaseMessage) <a href="#(latestURL)">#(strings.preReleaseLink)</a></p>
            </div>
            #else:
            <div class="admonition warning kiln-version-notice">
                <p>#(strings.oldVersionMessage) <a href="#(latestURL)">#(strings.oldVersionLink)</a></p>
            </div>
            #endif
            #endif#endif

            #if(page.isFallback):
            <div class="admonition kiln-fallback">
                <p class="admonition-title">#(strings.fallbackTitle)</p>
                <p>#(strings.fallbackMessage)</p>
            </div>
            #endif

            #import("content")

            <nav class="kiln-page-nav" aria-label="Page navigation">
                #if(nav.previous):<a class="kiln-prev" href="#(nav.previous.url)"><span class="kiln-page-nav-label">#(strings.previousPage)</span><span class="kiln-page-nav-title">#(nav.previous.title)</span></a>#endif
                #if(nav.next):<a class="kiln-next" href="#(nav.next.url)"><span class="kiln-page-nav-label">#(strings.nextPage)</span><span class="kiln-page-nav-title">#(nav.next.title)</span></a>#endif
            </nav>

            #if(page.editURL):<a class="kiln-edit-link" href="#(page.editURL)">#(strings.editPage)</a>#endif
        </main>

        <aside class="kiln-toc">
            #if(page.hasTOC):
            <div class="kiln-toc-inner">
                <p class="kiln-toc-title">#(strings.tableOfContentsTitle)</p>
                #extend("partials/toc")
            </div>
            #endif
            #if(site.carbonAds):
            <div class="kiln-carbon" id="kiln-carbon" data-serve="#(site.carbonAds.serve)" data-placement="#(site.carbonAds.placement)"></div>
            #endif
        </aside>
        </div>
    </div>
    </div>

    #extend("partials/footer")

    <!-- Search/version globals, read from the <body> data- attributes above.
         External (not inline) so the CSP needs no 'unsafe-inline' for scripts;
         must run before search.js, which reads window.kilnSearchIndex. -->
    <script src="/_kiln/js/search-init.js"></script>
    <!-- Shared chrome JS: Bootstrap, dark-mode toggle, syntax highlighting -->
    <script src="https://design.vapor.codes/main.js"></script>
    #if(site.searchEnabled):<script src="/_kiln/js/search.js"></script>#endif
    <script src="/_kiln/js/docs.js"></script>
    #for(src in site.extraJS):<script src="/#(src)"></script>
    #endfor
</body>
</html>
